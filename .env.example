# Traffic Predictor Environment Configuration
# Copy this file to .env and fill in your actual values

# ========================================
# DJANGO CONFIGURATION
# ========================================

# Secret Key (generate a new one in production: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
DJANGO_SECRET_KEY=your-very-long-secret-key-min-50-characters-change-in-production

# Debug Mode (false in production)
DJANGO_DEBUG=false

# Allowed Hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ========================================
# DATABASE CONFIGURATION
# ========================================

# Database Engine (sqlite3 for dev, postgresql for production)
DB_ENGINE=django.db.backends.postgresql

# PostgreSQL Configuration (if using PostgreSQL)
DB_NAME=traffic_predictor
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# ========================================
# EXTERNAL API KEYS
# ========================================

# OpenWeather API Key (get from: https://openweathermap.org/api)
OPENWEATHER_API_KEY=your-openweather-api-key

# NewsAPI Key (get from: https://newsapi.org/)
NEWSAPI_KEY=your-newsapi-key

# Nominatim User Agent
NOMINATIM_USER_AGENT=traffic-predictor-v2

# ========================================
# APPLICATION SETTINGS
# ========================================

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable Performance Metrics
ENABLE_METRICS=true

# Cache Backend (redis or locmem)
CACHE_BACKEND=redis://localhost:6379/0

# ========================================
# TIMEZONE
# ========================================

# Set to Asia/Kolkata for India
TIME_ZONE=Asia/Kolkata

# ========================================
# SECURITY SETTINGS (Production Only)
# ========================================

# CSRF Trusted Origins (comma-separated)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Secure SSL Redirect
SECURE_SSL_REDIRECT=false

# Session Cookie Secure
SESSION_COOKIE_SECURE=false

# HTTPS Only
SECURE_HSTS_SECONDS=0
